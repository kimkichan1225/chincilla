{
  "name": "chinchilla-pet",
  "version": "1.0.0",
  "description": "Desktop pet chinchilla",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.chinchilla.pet",
    "productName": "ChinchillaPet",
    "win": {
      "target": "dir",
      "sign": false
    },
    "files": [
      "main.js",
      "index.html",
      "Chinchilla/**/*"
    ],
    "portable": {
      "artifactName": "ChinchillaPet.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  }
}
